# Copy to .env for local dev. .env is gitignored.
# Dev-only, NON-SECRET prefill of the Connection screen's endpoint field.
# Access/secret keys are never prefilled — type them at the gate.
VITE_SPARCD_S3_ENDPOINT=

# Read allowlist (comma-separated bucket names or *-globs). Defaults to
# "sparcd,sparcd-*" when unset — broad reads across the sparcd family.
VITE_S3_BUCKETS=

# Write allowlist (comma-separated). EMPTY by default: wet uploads are refused
# until a vetted test bucket is named here. Clear the P4 review gates first.
VITE_S3_WRITE_BUCKETS=

# Production allowlist (comma-separated, P6). The subset of write-enabled
# buckets that are NOT disposable test buckets. A bucket here must ALSO be in
# VITE_S3_WRITE_BUCKETS to be writable; flagging it production adds a
# per-session in-app acknowledgment (reader-sentinel rollout + recorded second
# review) before any byte lands. EMPTY by default — the production lift is a
# deliberate, reviewed step.
VITE_S3_PROD_BUCKETS=
